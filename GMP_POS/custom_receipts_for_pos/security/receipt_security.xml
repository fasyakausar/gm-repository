<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ✅ Record rule: setiap company hanya bisa lihat receipt miliknya sendiri -->
        <record id="pos_receipt_company_rule" model="ir.rule">
            <field name="name">POS Receipt: Multi-Company</field>
            <field name="model_id" ref="model_pos_receipt"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
        </record>
    </data>
</odoo>