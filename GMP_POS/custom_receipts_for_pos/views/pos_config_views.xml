<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherits pos.config form view -->
    <record id="pos_config_view_form" model="ir.ui.view">
        <field name="name">pos.config.view.form.inherit.custom.receipts.for.pos</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='other_devices']" position="after">

                <!-- ══════════════════════════════════════════════════════════
                     Custom Receipt Design
                ══════════════════════════════════════════════════════════════ -->
                <setting title="Customize the POS receipts"
                         string="Custom Receipt"
                         help="Use custom receipt designs">
                    <field name="is_custom_receipt"/>
                    <div class="content-group mt16">
                        <field name="receipt_design"
                               invisible="not is_custom_receipt"
                               required="True"/>
                    </div>
                    <div class="content-group mt16">
                        <field name="design_receipt" invisible="1"/>
                    </div>
                </setting>

                <!-- ══════════════════════════════════════════════════════════
                     Logo Struk
                ══════════════════════════════════════════════════════════════ -->
                <setting string="Logo Struk"
                         help="Tampilkan logo perusahaan di bagian paling atas struk.">
                    <div class="content-group">
                        <div class="row mt8">
                            <label for="receipt_show_logo" class="col-lg-3 o_light_label"/>
                            <field name="receipt_show_logo" class="col-lg-9"/>
                        </div>
                        <div class="row mt4" invisible="not receipt_show_logo">
                            <label for="receipt_logo_height" class="col-lg-3 o_light_label"/>
                            <field name="receipt_logo_height" class="col-lg-3"
                                   placeholder="60"/>
                            <span class="col-lg-6 o_light_label" style="padding-top:5px;">px</span>
                        </div>
                        <!-- Preview logo saat ini -->
                        <div class="row mt4" invisible="not receipt_show_logo">
                            <label for="logo" class="col-lg-3 o_light_label"/>
                            <div class="col-lg-9">
                                <field name="logo" widget="image"
                                       options="{'size': [0, 60], 'preview_image': 'logo'}"/>
                            </div>
                        </div>
                    </div>
                </setting>

                <!-- ══════════════════════════════════════════════════════════
                     Bold per Section
                ══════════════════════════════════════════════════════════════ -->
                <setting string="Tebal Teks per Bagian Struk"
                         help="Aktifkan atau nonaktifkan teks tebal (bold) untuk setiap bagian struk secara terpisah.">
                    <div class="content-group">
                        <div class="row mt8">
                            <label for="receipt_bold_header" class="col-lg-5 o_light_label"/>
                            <field name="receipt_bold_header" class="col-lg-7"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_bold_info" class="col-lg-5 o_light_label"/>
                            <field name="receipt_bold_info" class="col-lg-7"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_bold_items" class="col-lg-5 o_light_label"/>
                            <field name="receipt_bold_items" class="col-lg-7"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_bold_total" class="col-lg-5 o_light_label"/>
                            <field name="receipt_bold_total" class="col-lg-7"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_bold_summary" class="col-lg-5 o_light_label"/>
                            <field name="receipt_bold_summary" class="col-lg-7"/>
                        </div>
                    </div>
                </setting>

                <!-- ══════════════════════════════════════════════════════════
                     Alamat Struk per POS
                ══════════════════════════════════════════════════════════════ -->
                <setting string="Alamat Struk"
                         help="Informasi yang ditampilkan di header struk untuk toko ini.">
                    <div class="content-group">
                        <div class="row mt8">
                            <label for="receipt_store_name" class="col-lg-3 o_light_label"/>
                            <field name="receipt_store_name" class="col-lg-9"
                                   placeholder="GMP Elektrik Lippo Cikarang"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_company_name" class="col-lg-3 o_light_label"/>
                            <field name="receipt_company_name" class="col-lg-9"
                                   placeholder="PT GLOBAL MULTIPARTS"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_street" class="col-lg-3 o_light_label"/>
                            <field name="receipt_street" class="col-lg-9"
                                   placeholder="Jl. Sriwijaya Ruko Olimpic Blok A.8 Cibatu"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_city_zip" class="col-lg-3 o_light_label"/>
                            <field name="receipt_city_zip" class="col-lg-9"
                                   placeholder="Lippo Cikarang 17550"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_phone" class="col-lg-3 o_light_label"/>
                            <field name="receipt_phone" class="col-lg-9"
                                   placeholder="(021) 89841952"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_wa" class="col-lg-3 o_light_label"/>
                            <field name="receipt_wa" class="col-lg-9"
                                   placeholder="0877-7909-0747"/>
                        </div>
                        <div class="row mt4">
                            <label for="receipt_npwp" class="col-lg-3 o_light_label"/>
                            <field name="receipt_npwp" class="col-lg-9"
                                   placeholder="021.100.283.7-413.000"/>
                        </div>
                    </div>
                </setting>

            </xpath>
        </field>
    </record>
</odoo>