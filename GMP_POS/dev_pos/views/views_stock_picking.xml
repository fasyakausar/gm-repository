<odoo>
  <data>

    <!-- form view-->
    <record model="ir.ui.view" id="view_stock_picking_form">
      <field name="name">stock.picking.form</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form"/>
      <field name="arch" type="xml">
       <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/field[@name='location_dest_id'][2]" position="after">
            <field name="target_location"/>
            <field name="stock_type"/>
        </xpath>
        <xpath expr="//field[@name='origin']" position="after">
            <field name="is_integrated"/>
            <field name="is_closed"/>
            <field name="vit_trxid"/>
            <field name="gm_type_transfer"/>
            <field name="barcode_input" placeholder="Scan barcode here..." class="oe_inline" style="font-size: 18px; font-weight: bold;"/>
        </xpath>
        
        <!-- Field origin readonly ketika state ready/done -->
        <field name="origin" position="attributes">
            <attribute name="readonly">state in ['assigned', 'done']</attribute>
        </field>
        
        <!-- Field stock_type readonly ketika state ready/done -->
        <field name="stock_type" position="attributes">
            <attribute name="readonly">state in ['assigned', 'done']</attribute>
        </field>
        
        <!-- Field location_id readonly ketika state ready/done -->
        <field name="location_id" position="attributes">
            <attribute name="readonly">state in ['assigned', 'done']</attribute>
        </field>
        
        <!-- Field location_dest_id readonly ketika state ready/done -->
        <field name="location_dest_id" position="attributes">
            <attribute name="readonly">state in ['assigned', 'done']</attribute>
        </field>
        
        <xpath expr="//field[@name='is_integrated']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
        <xpath expr="//field[@name='vit_trxid']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
        <xpath expr="//field[@name='is_closed']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
      </field>
    </record>

    <!-- tree view -->
    <record model="ir.ui.view" id="view_stock_picking_tree">
      <field name="name">stock.picking.tree</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.vpicktree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='origin']" position="after">
          <field name="vit_trxid"/>
          <field name="is_integrated"/>
        </xpath>
      </field>
    </record>

    <!-- search view -->
    <record model="ir.ui.view" id="view_stock_picking_search">
      <field name="name">stock.picking.search</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_internal_search"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='origin']" position="after">
          <field name="vit_trxid"/>
        </xpath>
      </field>
    </record>

  </data>
</odoo>