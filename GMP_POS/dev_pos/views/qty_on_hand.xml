<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. SALE ORDER FORM - TREE VIEW (Desktop) -->
    <record id="view_order_form_qty_on_hand_tree" model="ir.ui.view">
        <field name="name">sale.order.form.qty.on.hand.tree</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_uom_qty']" position="after">
                <field name="qty_on_hand"
                       string="On Hand"
                       readonly="1"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- 2. SALE ORDER FORM - INLINE FORM (Mobile Dialog) -->
    <record id="view_order_form_qty_on_hand_mobile" model="ir.ui.view">
        <field name="name">sale.order.form.qty.on.hand.mobile</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//form//div[@name='ordered_qty']" position="after">
                <label for="qty_on_hand"
                       string="Qty On Hand"
                       invisible="display_type"/>
                <div name="qty_on_hand_div" invisible="display_type">
                    <field name="qty_on_hand"
                           class="oe_inline"
                           readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- 3. SALE ORDER LINE - STANDALONE TREE VIEW -->
    <record id="view_order_line_tree_qty_on_hand" model="ir.ui.view">
        <field name="name">sale.order.line.tree.qty.on.hand</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_qty']" position="after">
                <field name="qty_on_hand"
                       string="On Hand"
                       readonly="1"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!--
        1. Field show_qty_on_hand (hidden)
           Ditempatkan setelah field picking_type_code yang sudah ada di form
    -->
    <record id="view_picking_form_show_qty_on_hand" model="ir.ui.view">
        <field name="name">stock.picking.form.show.qty.on.hand</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_code'][@invisible='1'][1]" position="after">
                <field name="show_qty_on_hand" invisible="1"/>
            </xpath>
        </field>
    </record>

    <!--
        2. Tab Operations - kolom qty_on_hand setelah product_uom_qty (Demand)
           Berdasarkan kode asli: field product_uom_qty string="Demand"
           Hanya tampil jika picking_type_code = outgoing
    -->
    <record id="view_picking_form_qty_on_hand_move" model="ir.ui.view">
        <field name="name">stock.picking.form.qty.on.hand.move</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='move_ids_without_package']//tree//field[@name='product_uom_qty']" position="after">
                <field name="qty_on_hand"
                       string="On Hand"
                       readonly="1"
                       optional="show"
                       column_invisible="parent.picking_type_code != 'outgoing'"/>
            </xpath>
        </field>
    </record>

</odoo>