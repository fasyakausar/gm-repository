<odoo>
  <data>
  
    <record model="ir.ui.view" id="view_purchase_order_form">
      <field name="name">purchase.order.form</field>
      <field name="model">purchase.order</field>
      <field name="inherit_id" ref="purchase.purchase_order_form"/>
      <field name="arch" type="xml">
        <data>
            <xpath expr="//div[@name='reminder']" position="after">
                <field name="vit_trxid"/>
                <field name="is_integrated"/>
            </xpath>
            <xpath expr="//field[@name='is_integrated']" position="attributes">
                <attribute name="force_save">1</attribute>
                <attribute name="readonly">True</attribute>
            </xpath>
            <xpath expr="//field[@name='vit_trxid']" position="attributes">
                <attribute name="force_save">1</attribute>
                <attribute name="readonly">True</attribute>
            </xpath>

            <xpath expr="//button[@name='button_unlock']" position="attributes">
                <attribute name="invisible">state == 'done'</attribute>
            </xpath>
        </data>
      </field>
    </record>

    <!-- tree view -->
    <record model="ir.ui.view" id="view_purchase_order_tree">
      <field name="name">purchase.order.tree</field>
      <field name="model">purchase.order</field>
      <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <field name="vit_trxid"/>
        </xpath>
      </field>
    </record>

    <!-- search view -->
    <record model="ir.ui.view" id="view_purchase_order_search">
      <field name="name">purchase.order.search</field>
      <field name="model">purchase.order</field>
      <field name="inherit_id" ref="purchase.purchase_order_view_search"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='name']" position="after">
          <field name="vit_trxid"/>
        </xpath>
      </field>
    </record>

  </data>
</odoo>