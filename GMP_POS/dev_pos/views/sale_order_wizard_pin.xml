<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sale_price_pin_wizard_form" model="ir.ui.view">
        <field name="name">sale.price.pin.wizard.form</field>
        <field name="model">sale.price.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Ubah Harga - Validasi PIN Manager">
                <sheet>
                    <group>
                        <group string="Informasi Order">
                            <field name="order_id" readonly="1"/>
                            <field name="order_line_id"
                                   domain="[('order_id', '=', order_id)]"
                                   required="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="current_price" readonly="1"/>
                        </group>
                        <group string="Harga Baru">
                            <field name="new_price" required="1"/>
                            <field name="pin"
                                   password="True"
                                   required="1"
                                   placeholder="Masukkan PIN Manager"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_validate"
                            string="Konfirmasi"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_cancel"
                            string="Batal"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_sale_order_form_inherit_price" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.price.wizard</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Tambah button di header -->
            <xpath expr="//header" position="inside">
                <button name="action_open_price_wizard"
                        string="Ubah Harga"
                        type="object"
                        class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>