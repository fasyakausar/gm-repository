<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_manager_validation_res_config_settings" model="ir.ui.view">
        <field name="name">pos.manager.validation.res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <app data-string="Point of sale" string="Point of Sale" name="point_of_sale" groups="point_of_sale.group_pos_manager">
                
                <!-- Pricelist Configuration Block -->
                <block title="Pricelist Configuration" id="pos_pricelist_configuration">
                    <setting id="pricelist_configuration" string="Pricelist Configuration"
                        help="Enable POSVIT 2.0 Pricelist Configuration.">
                        <field name="pricelist_configuration"/>
                    </setting>
                    <setting id="vit_cust_pricelist" string="Customer Pricelist"
                        help="Use individual customer pricelist when available."
                        invisible="pricelist_configuration != True">
                        <field name="vit_cust_pricelist"/>
                    </setting>
                    <setting id="vit_cust_group_pricelist" string="Customer Group Pricelist"
                        help="Use customer group pricelist when customer group is assigned."
                        invisible="pricelist_configuration != True">
                        <field name="vit_cust_group_pricelist"/>
                    </setting>
                </block>

                <!-- Return Approval Configuration Block -->
                <block title="Return Approval" id="pos_return_approval_configuration">
                    <setting id="return_approval_multi_level" 
                             string="Multi-Level Return Approval"
                             help="Enable two-level approval workflow for POS return requests.">
                        <field name="gm_use_multi_level_approval"/>
                        <div class="content-group mt-3" invisible="gm_use_multi_level_approval != True">
                            <div class="text-muted">
                                When enabled, return approvals require two levels:
                                <ul class="mb-0 mt-1">
                                    <li><strong>Level 2 (Manager):</strong> First approval</li>
                                    <li><strong>Level 1 (Supervisor):</strong> Final approval</li>
                                </ul>
                                When disabled, only Level 1 approval is required.
                            </div>
                            
                            <!-- Info Alert -->
                            <div class="alert alert-info mt-3" role="alert">
                                <i class="fa fa-info-circle"/> 
                                <strong>Note:</strong> Make sure to assign the appropriate user groups:
                                <ul class="mb-0 mt-2">
                                    <li><em>Return Approval Level 1</em> - for supervisors</li>
                                    <li><em>Return Approval Level 2</em> - for managers</li>
                                </ul>
                            </div>
                        </div>
                    </setting>
                </block>

                <!-- AUTO ROUNDING CONFIGURATION -->
                <block title="Auto Rounding Configuration" id="pos_auto_rounding_section">
                    <setting id="enable_auto_rounding" string="Enable Auto Rounding"
                        help="Automatically round total amount to nearest rounding value when clicking payment button.">
                        <field name="enable_auto_rounding"/>
                        <div class="text-muted" invisible="enable_auto_rounding != True">
                            System will automatically round to the nearest value (up or down).
                        </div>
                    </setting>
                    <setting id="rounding_value" string="Rounding Value"
                        help="Value to round to (e.g., 100 for hundreds, 1000 for thousands)."
                        invisible="enable_auto_rounding != True">
                        <field name="rounding_value"/>
                        <div class="text-muted">
                            Example: 100 → rounds to nearest hundred (11,150 → 11,200 or 11,140 → 11,100)
                        </div>
                    </setting>
                    <setting id="rounding_product_id" string="Rounding Product"
                        help="Product used for rounding adjustment line in POS."
                        invisible="enable_auto_rounding != True">
                        <field name="rounding_product_id" 
                               domain="[('available_in_pos', '=', True)]"
                               context="{'default_available_in_pos': True}"/>
                    </setting>
                </block>

            </app>
        </field>
    </record>
</odoo>