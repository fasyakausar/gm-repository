<odoo>
  <data>

    <!-- form view-->
    <record model="ir.ui.view" id="view_loyalty_program_form">
      <field name="name">loyalty.program.form</field>
      <field name="model">loyalty.program</field>
      <field name="inherit_id" ref="loyalty.loyalty_program_view_form"/>
      <field name="arch" type="xml">

        <!-- tambahkan is_admin_access di sini, sebelum xpath lainnya -->
        <field name="active" position="after">
            <field name="is_admin_access" invisible="1"/>
        </field>

        <!-- sembunyikan smart button -->
        <button name="action_open_loyalty_cards" position="attributes">
            <attribute name="invisible">not is_admin_access</attribute>
        </button>

        <!-- sembunyikan button Generate Gift Cards -->
        <xpath expr="//header/button[2]" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>

        <xpath expr="//field[@name='date_to']" position="after">
            <field name="is_integrated"/>
            <field name="is_updated"/>
            <field name="index_store" widget="many2many_tags"/>
            <field name="vit_trxid"/>
        </xpath>
        <xpath expr="//page[@name='rules_rewards']" position="after">
            <page string="Schedules" name="schedules">
                <field name="schedule_ids">
                    <tree editable="bottom">
                        <field name="days"/>
                        <field name="time_start" widget="time"/>
                        <field name="time_end" widget="time"/>
                    </tree>
                </field>
            </page>
        </xpath>
        <xpath expr="//page[@name='rules_rewards']" position="after">
            <page string="Member Promo" name="member">
                <field name="member_ids">
                    <tree editable="bottom">
                        <field name="member_pos"/>
                    </tree>
                </field>
            </page>
        </xpath>
        <xpath expr="//page[@name='rules_rewards']" position="after">
            <page string="Redeem Point" name="redeem" invisible="program_type != 'loyalty'">
                <group>
                    <field name="vit_konversi_poin"/>
                </group>
            </page>
        </xpath>
        <xpath expr="//field[@name='is_integrated']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>
        <xpath expr="//field[@name='vit_trxid']" position="attributes">
          <attribute name="force_save">1</attribute>
          <attribute name="readonly">True</attribute>
        </xpath>

      </field>
    </record>

  </data>
</odoo>