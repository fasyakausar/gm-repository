<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- tree View -->
    <record id="view_mapping_tax_tree" model="ir.ui.view">
        <field name="name">mapping.tax.tree</field>
        <field name="model">mapping.tax</field>
        <field name="arch" type="xml">
            <tree string="Mapping Tax" editable="bottom">
                <field name="company_id"/>
                <field name="gm_warehouse_id"/>
                <field name="gm_tax_code"/>
                <field name="gm_tax_code_0"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_mapping_tax_form" model="ir.ui.view">
        <field name="name">mapping.tax.form</field>
        <field name="model">mapping.tax</field>
        <field name="arch" type="xml">
            <form string="Mapping Tax">
                <sheet>
                    <group>
                        <group string="Company &amp; Warehouse">
                            <field name="company_id"/>
                            <field name="gm_warehouse_id"
                                   domain="[('company_id', '=', company_id)]"/>
                        </group>
                        <group string="Tax Configuration">
                            <field name="gm_tax_code"
                                   domain="[('company_id', '=', company_id), ('type_tax_use', '=', 'sale')]"/>
                            <field name="gm_tax_code_0"
                                   domain="[('company_id', '=', company_id), ('type_tax_use', '=', 'sale')]"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mapping_tax" model="ir.actions.act_window">
        <field name="name">Mapping Tax</field>
        <field name="res_model">mapping.tax</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tambahkan mapping tax baru
            </p>
            <p>
                Mapping tax digunakan untuk menentukan kode pajak
                berdasarkan warehouse dan company.
            </p>
        </field>
    </record>

    <!-- Menu — sesuaikan parent menu dengan modul Anda -->
    <menuitem id="menu_mapping_tax"
              name="Mapping Tax"
              parent="account.menu_finance"
              action="action_mapping_tax"
              sequence="80"/>

</odoo>