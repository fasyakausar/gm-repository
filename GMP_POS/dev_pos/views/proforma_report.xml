<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Template Report Proforma Invoice -->
        <template id="report_proforma_invoice_document">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)" />
                <t t-set="proforma" t-value="True" />
                
                <!-- Title: PROFORMA INVOICE -->
                <div class="text-center mb-4">
                    <h2><strong>PROFORMA INVOICE</strong></h2>
                </div>
                
                <!-- Invoice Information -->
                <div class="row mb-4">
                    <div class="col-6">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td><strong>Number:</strong></td>
                                <td><span t-field="o.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Date:</strong></td>
                                <td><span t-field="o.date_order" t-options='{"widget": "date"}'/></td>
                            </tr>
                            <tr t-if="o.validity_date">
                                <td><strong>Validity Date:</strong></td>
                                <td><span t-field="o.validity_date"/></td>
                            </tr>
                            <tr t-if="o.client_order_ref">
                                <td><strong>Customer Ref:</strong></td>
                                <td><span t-field="o.client_order_ref"/></td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-6">
                        <table class="table table-sm table-borderless">
                            <tr t-if="o.partner_shipping_id and o.partner_shipping_id != o.partner_id">
                                <td><strong>SHIP TO:</strong></td>
                                <td>
                                    <span t-field="o.partner_shipping_id.name"/><br/>
                                    <span t-field="o.partner_shipping_id.street" t-if="o.partner_shipping_id.street"/><br/>
                                    <span t-field="o.partner_shipping_id.street2" t-if="o.partner_shipping_id.street2"/><br/>
                                    <span t-field="o.partner_shipping_id.city" t-if="o.partner_shipping_id.city"/>
                                    <span t-field="o.partner_shipping_id.state_id.name" t-if="o.partner_shipping_id.state_id"/><br/>
                                    <span t-field="o.partner_shipping_id.country_id.name" t-if="o.partner_shipping_id.country_id"/>
                                </td>
                            </tr>
                            <tr t-if="o.payment_term_id">
                                <td><strong>Payment Terms:</strong></td>
                                <td><span t-field="o.payment_term_id.note"/></td>
                            </tr>
                        </table>
                    </div>
                </div>
                
                <!-- Order Lines Table -->
                <table class="table table-bordered">
                    <thead>
                        <tr style="background-color: #f2f2f2;">
                            <th class="text-center" style="width: 5%;">#</th>
                            <th class="text-start" style="width: 45%;">Description</th>
                            <th class="text-center" style="width: 10%;">Quantity</th>
                            <th class="text-center" style="width: 15%;">Unit Price</th>
                            <th class="text-center" style="width: 10%;">Discount</th>
                            <th class="text-end" style="width: 15%;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="line_number" t-value="1"/>
                        <t t-foreach="o.order_line" t-as="line">
                            <t t-if="line.display_type != 'line_section' and line.display_type != 'line_note'">
                                <tr>
                                    <td class="text-center" t-out="line_number"/>
                                    <td class="text-start">
                                        <span t-field="line.product_id.name"/><br/>
                                        <small><span t-field="line.name" t-options="{'widget': 'text'}"/></small>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.product_uom_qty"/>
                                        <span t-field="line.product_uom.name" groups="uom.group_uom"/>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="line.discount" t-if="line.discount > 0"/>
                                        <span t-if="line.discount == 0">-</span>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                                <t t-set="line_number" t-value="line_number + 1"/>
                            </t>
                        </t>
                    </tbody>
                </table>
                
                <!-- Totals Section -->
                <div class="row mt-4">
                    <div class="col-8">
                        <!-- Terms and Conditions -->
                        <div t-if="o.note">
                            <strong>Terms and Conditions:</strong><br/>
                            <div style="text-align: justify; text-justify: inter-word;">
                                <span t-field="o.note" t-options="{'widget': 'text'}"/>
                            </div>
                        </div>
                        
                        <!-- Disclaimer -->
                        <div class="mt-4">
                            <p class="text-muted">
                                <small>
                                    <strong>NOTE:</strong> Faktur sementara atau dokumen penawaran harga resmi yang dikirimkan penjual kepada pembeli sebelum barang/jasa dikirimkan.
                                </small>
                            </p>
                        </div>
                    </div>
                    
                    <div class="col-4">
                        <!-- Summary Table -->
                        <table class="table table-sm table-borderless float-end" style="width: 80%;">
                            <tr>
                                <td class="text-end"><strong>Subtotal:</strong></td>
                                <td class="text-end" style="width: 40%;">
                                    <span t-field="o.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </tr>
                            
                            <!-- Tax Lines -->
                            <t t-set="taxes_summary" t-value="{}"/>
                            <t t-foreach="o.order_line" t-as="line">
                                <t t-if="line.tax_id">
                                    <t t-foreach="line.tax_id" t-as="tax">
                                        <t t-set="tax_key" t-value="str(tax.id)"/>
                                        <t t-set="tax_amount" t-value="line.price_subtotal * tax.amount / 100"/>
                                        <t t-if="tax_key in taxes_summary">
                                            <t t-set="taxes_summary" t-value="dict(taxes_summary, **{tax_key: taxes_summary[tax_key] + tax_amount})"/>
                                        </t>
                                        <t t-else="">
                                            <t t-set="taxes_summary" t-value="dict(taxes_summary, **{tax_key: tax_amount})"/>
                                        </t>
                                    </t>
                                </t>
                            </t>

                            <!-- Kemudian tampilkan taxes -->
                            <t t-foreach="taxes_summary.items()" t-as="tax_item">
                                <tr>
                                    <td class="text-end">
                                        <!-- Cari nama tax berdasarkan ID -->
                                        <t t-set="tax_id" t-value="int(tax_item[0])"/>
                                        <t t-set="tax_name" t-value="''"/>
                                        <t t-foreach="o.order_line.mapped('tax_id')" t-as="tax">
                                            <t t-if="tax.id == tax_id">
                                                <t t-set="tax_name" t-value="tax.name"/>
                                            </t>
                                        </t>
                                        <span t-out="tax_name"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-out="tax_item[1]" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                            
                            <tr style="border-top: 2px solid #000;">
                                <td class="text-end"><strong>TOTAL:</strong></td>
                                <td class="text-end">
                                    <strong>
                                        <span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </t>
        </template>
        
        <!-- Main Report Template -->
        <template id="report_proforma_invoice">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="lang" t-value="o.partner_id.lang"/>
                    <t t-call="dev_pos.report_proforma_invoice_document" t-lang="lang"/>
                </t>
            </t>
        </template>
        
        <!-- Report Action Definition -->
        <record id="action_report_proforma_invoice" model="ir.actions.report">
            <field name="name">Proforma Invoice</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">dev_pos.report_proforma_invoice</field>
            <field name="print_report_name">'PROFORMA - %s' % (object.name)</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_type">report</field>
        </record>
        
        <!-- Add Print Proforma Button to Sale Order Form -->
        <record id="view_order_form_proforma_button" model="ir.ui.view">
            <field name="name">sale.order.form.proforma.button</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_preview_sale_order']" position="after">
                    <button name="%(action_report_proforma_invoice)d" 
                            type="action" 
                            string="Print Proforma"
                            class="btn-secondary"
                            context="{'proforma': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>