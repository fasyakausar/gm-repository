<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_barcode_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.barcode</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
        <field name="arch" type="xml">
            <!-- Hapus warehouse_id dari posisi aslinya -->
            <xpath expr="//field[@name='warehouse_id']" position="replace"/>
            
            <!-- Pindahkan warehouse_id setelah payment_term_id -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="warehouse_id" invisible="1" readonly="state == 'sale'"/>
                <field name="warehouse_id" options="{'no_create': True}" groups="stock.group_stock_multi_warehouses" force_save="1" readonly="state == 'sale'"/>
            </xpath>
            
            <!-- Tambahkan barcode input setelah warehouse_id -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="barcode_input" 
                       placeholder="Scan barcode here..." 
                       class="oe_inline"
                       style="font-size: 18px; font-weight: bold;"
                       invisible="state not in ['draft', 'sent']"/>
            </xpath>
        </field>
    </record>
</odoo>